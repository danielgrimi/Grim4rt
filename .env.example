# --- Supabase Postgres: two distinct pooler connections ---
# See docs/superpowers/specs/2026-07-14-admin-panel-design.md → "Two database
# connections" for the full rationale. These are Supavisor POOLER modes, not a
# true direct Postgres connection.
#
# Both should authenticate as the dedicated `prisma` role, not the default
# `postgres` superuser — run prisma/role-setup.sql once (manually, in the
# Supabase SQL Editor) to create it, then use `prisma.[project-ref]` as the
# username below instead of `postgres.[project-ref]`.

# Supavisor TRANSACTION pooler (port 6543) — used ONLY by the runtime Prisma
# Client (src/lib/prisma.ts). Suited to serverless functions opening many
# short-lived connections per request.
DATABASE_URL="postgresql://prisma.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supavisor SESSION pooler (port 5432) — used ONLY by prisma.config.ts
# (prisma migrate / prisma db push / Prisma Studio). Holds a stable
# connection suited to schema changes.
DIRECT_URL="postgresql://prisma.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# --- Supabase project + Storage (artwork-images bucket) ---
# Project Settings > API. "Publishable" is the new name for what used to be
# called the anon key — safe to expose client-side (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="[publishable key from Supabase dashboard > Project Settings > API]"
# Server-only secret — new name for what used to be called the service_role
# key. Never exposed to the client, never prefixed NEXT_PUBLIC_.
SUPABASE_SECRET_KEY="[secret key from Supabase dashboard > Project Settings > API]"

# --- Auth ---
# Login is real Supabase Auth (email + password) — create the one admin
# account in the Supabase dashboard under Authentication > Users, then copy
# that user's UUID here. requireAdmin() checks the logged-in user's id
# against this value; anyone else's Supabase Auth login is rejected.
ADMIN_USER_ID=""
